{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "cross-platform",
  "description": "Capability for the main window on Windows and Linux",
  "windows": [
    "main",
    "dashboard"
  ],
  "platforms": [
    "windows",
    "linux"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "keychain:default",
    "keychain:allow-get-item",
    "keychain:allow-save-item",
    "keychain:allow-remove-item",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "shell:allow-open",
    "core:window:allow-start-dragging",
    "sql:default",
    "sql:allow-execute",
    "posthog:default",
    "posthog:allow-capture",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.openai.com/**"
        },
        {
          "url": "https://api.anthropic.com/**"
        },
        {
          "url": "https://api.x.ai/**"
        },
        {
          "url": "https://api.mistral.ai/**"
        },
        {
          "url": "https://api.cohere.ai/**"
        },
        {
          "url": "https://api.groq.com/**"
        },
        {
          "url": "https://api.perplexity.ai/**"
        },
        {
          "url": "https://openrouter.ai/**"
        },
        {
          "url": "https://integrate.api.nvidia.com/**"
        },
        {
          "url": "https://api.elevenlabs.io/**"
        },
        {
          "url": "https://pluely.com/**"
        },
        {
          "url": "https://*.googleapis.com/**"
        },
        {
          "url": "https://*.azure.com/**"
        },
        {
          "url": "http://localhost/**"
        },
        {
          "url": "https://localhost/**"
        },
        {
          "url": "http://127.0.0.1/**"
        },
        {
          "url": "https://127.0.0.1/**"
        }
      ]
    }
  ]
}